{
  "name": "skill-b-pre-brief",
  "display_name": "会前简报 (pre_brief)",
  "version": "1.0.0",
  "description": "cron 每 15 分钟触发。遍历所有受管仓库，筛选距会议开始 30 分钟至 4 小时内、status==scheduled 的会议，自动生成按人汇总的会前简报并发送邮件给全员。",
  "entry": "main.py",
  "trigger": "cron",
  "cron": "*/15 * * * *",
  "author": "AIFusion",
  "requires_env": [
    "GITEA_TOKEN_BOT",
    "GITEA_BASE_URL",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASSWORD",
    "MINIMAX_API_KEY",
    "AIFUSION_META_REPO"
  ]
}